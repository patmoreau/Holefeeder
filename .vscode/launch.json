{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Docker .NET Core Launch (docker-compose)",
            "type": "docker",
            "request": "launch",
            "preLaunchTask": "docker-compose-run: debug",
            "dockerCompose": {
                "dockerComposeFile": "${workspaceFolder}/docker-compose.yml",
                "service": "holefeederapi"
            },
            "netCore": {
                "appProject": "${workspaceFolder}/src/Api/Holefeeder.Api/Holefeeder.Api.csproj",
                "enableDebugging": true
            }
        },
        {
            "name": "Docker .NET Launch",
            "type": "docker",
            "request": "launch",
            "preLaunchTask": "docker-run: debug",
            "netCore": {
                "appProject": "${workspaceFolder}/src/Api/Holefeeder.Api/Holefeeder.Api.csproj"
            }
        }
    ]
}
